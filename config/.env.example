# ============================================
# EDDIE VIBE MARKETER V2 - ENVIRONMENT VARIABLES
# Copy this to .env and fill in your keys
# ============================================

# --- Phase 1: Ad Research ---
APIFY_API_TOKEN=your_apify_token_here
# Get from: https://console.apify.com/account/integrations

# --- Phase 1: Transcription ---
OPENAI_API_KEY=your_openai_key_here
# Get from: https://platform.openai.com/api-keys
# Used for Whisper transcription of competitor video ads

# --- Phase 3: Script Generation ---
ANTHROPIC_API_KEY=your_anthropic_key_here
# Get from: https://console.anthropic.com/settings/keys
# Used for Claude to generate content + quality gate + Browser Use publisher

# --- Phase 4: Avatar Video Production ---
HEYGEN_API_KEY=your_heygen_key_here
# Get from: https://app.heygen.com/settings (Creator plan: $29/mo unlimited)
# Used for ICP-matched avatar video generation

ARGIL_API_KEY=your_argil_key_here
# Get from: https://app.argil.ai/settings (Pro plan: $149/mo)
# Used for personal clone video generation (optional)

# --- Phase 5: Performance Loop ---
SINGULAR_API_KEY=your_singular_key_here
# Get from: https://app.singular.net/
# Used to pull ad performance data (CPA, ROAS, etc.)

# --- Script Generation Model ---
CLAUDE_MODEL=claude-haiku-4-5-20251001
# Default: claude-haiku-4-5-20251001 (~$0.01 per script, fast)
# Upgrade to claude-sonnet-4-6 for higher quality (~$0.10 per script)
# Upgrade to claude-opus-4-6 for best quality (~$0.50 per script)

# --- Optional ---
SLACK_WEBHOOK_URL=your_slack_webhook_here
# For notifications when a cycle completes
